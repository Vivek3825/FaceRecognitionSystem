    print("   POST /api/rebuild-embeddings - Rebuild embeddings (recovery)")
    print("   GET  /api/verify-consistency - Check data consistency")
    print("   GET  /dataset/<path>       - Serve dataset files")
    print("-" * 50)
    
    app.run(host='0.0.0.0', port=5000, debug=True)